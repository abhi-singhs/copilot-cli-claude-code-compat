  Claude Code /fork <directive> → Copilot CLI /fleet <directive> (v2.1.161+ spawns a
    background subagent; previously /fork was an alias for /branch)
  /sandbox → Copilot CLI /sandbox [enable|disable] (configure shell sandboxing)
  /permissions → no Copilot /permissions command; use /allow-all or
    /reset-allowed-tools (session-scoped tool permissions)
  Claude Code /deep-research → Copilot CLI /research (best-effort; pipelines
    differ: Claude Code fans out web searches, Copilot uses GitHub + web)
  Claude Code /feedback alias /share differs from Copilot CLI /share (which
    exports the session: /share [file|html|gist] ...) — same name, different action
  Claude Code --worktree (-w) launch flag → no Copilot CLI equivalent
    (no worktree launch flag or slash command); run 'git worktree' manually

Prompt mode env vars (set to 'true' to enable in -p mode):
  GITHUB_COPILOT_PROMPT_MODE_EXTENSIONS    Load project extensions
  GITHUB_COPILOT_PROMPT_MODE_REPO_HOOKS    Load repository hooks
  GITHUB_COPILOT_PROMPT_MODE_WORKSPACE_MCP Load workspace MCP sources
"""


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    args = sys.argv[1:]

    # --- cpc-specific flags ---
    if "--help" in args and not any(a in ("-p", "--print") for a in args):
        print(HELP_TEXT)
        return

    dry_run = "--dry-run" in args
    if dry_run:
        args = [a for a in args if a != "--dry-run"]

    # --- No arguments → interactive ---
    if not args:
        cmd = [COPILOT_BIN]
        if dry_run:
            print(" ".join(cmd))
            return
        run(cmd)
        return

    # --- Check for subcommand as first positional arg ---
    first = args[0]
    if not is_flag(first) and first in SUBCOMMANDS:
        result = handle_subcommand(first, args[1:])
        if result is None:
            return
        if dry_run:
            print(" ".join(result))
            return
        run(result)
        return

    # --- Translate flags ---
    copilot_args, has_prompt_flag, bare_positionals = translate_flags(args)

    # --- Handle bare positionals (query strings) ---
    if bare_positionals:
        query = " ".join(bare_positionals)
        if has_prompt_flag:
            # -p was already added; append query after it
            copilot_args.append(query)
        else:
            # No -p flag → use -i for interactive with initial prompt
            copilot_args.append("-i")
            copilot_args.append(query)

    cmd = [COPILOT_BIN] + copilot_args

    if dry_run:
        print(" ".join(cmd))
        return

    run(cmd)


def run(cmd):
    """Execute the copilot command, replacing the process on Unix."""
    try:
        if sys.platform == "win32":
            import subprocess
            result = subprocess.run(cmd)
            sys.exit(result.returncode)
        else:
            os.execvp(cmd[0], cmd)
    except FileNotFoundError:
        print(
            f"cpc: error: '{cmd[0]}' not found on PATH.\n"
            "Install GitHub Copilot CLI: https://docs.github.com/en/copilot/how-tos/set-up/install-copilot-cli",
            file=sys.stderr,
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
