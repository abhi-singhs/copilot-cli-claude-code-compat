#!/usr/bin/env python3
"""cpc - Claude Code compatibility wrapper for GitHub Copilot CLI.

Translates Claude Code CLI syntax to Copilot CLI commands. Keeps 'claude'
pointing at real Claude Code while letting you use familiar syntax with Copilot.
"""

import os
import re
import sys

COPILOT_BIN = os.environ.get("CPC_BINARY", "copilot")

# ---------------------------------------------------------------------------
# Tool permission syntax conversion
# ---------------------------------------------------------------------------

TOOL_PERMISSION_MAP = {
    "Bash": "shell",
    "Read": "read",
    "Edit": "write",
    "Write": "write",
    "WebFetch": "url",
    "ListFiles": "glob",
    "Grep": "grep",
}

TOOL_AVAILABLE_MAP = {
    "Bash": "bash",
    "Read": "view",
    "Edit": "edit",
    "Write": "create",
    "WebFetch": "web_fetch",
    "ListFiles": "glob",
    "Grep": "grep",
}

_TOOL_RE = re.compile(r"^([A-Za-z]+)(\(.*\))?$")
_MCP_RE = re.compile(r"^mcp__([^_]+(?:__[^_]+)?)__(\w+)$")


def convert_tool_pattern(pattern):
    """Convert a Claude Code tool pattern to Copilot CLI format.

    Examples:
        Bash(git log *)      -> shell(git log)
        Read                 -> read
        mcp__github__create  -> github(create)
    """
    mcp_m = _MCP_RE.match(pattern)
    if mcp_m:
        server = mcp_m.group(1).replace("__", "-")
        tool = mcp_m.group(2)
        return f"{server}({tool})"

    m = _TOOL_RE.match(pattern)
    if m:
        name = m.group(1)
        args = m.group(2)  # includes parens or None
        mapped = TOOL_PERMISSION_MAP.get(name)
        if mapped:
            return f"{mapped}{args}" if args else mapped
    return pattern  # pass through unknown


def convert_tool_for_available(name):
    """Convert a Claude Code tool name for --available-tools."""
    return TOOL_AVAILABLE_MAP.get(name.strip(), name.strip().lower())


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Passthrough flags that consume the next argument as their value.
# These must consume their value so it's not mistaken for a bare query.
PASSTHROUGH_VALUE_FLAGS = {
    "--model", "--add-dir", "--agent", "--output-format",
    "--resume", "--session-id", "--log-level", "--log-dir",
    "--mcp-config", "--additional-mcp-config", "--name",
    "--attachment", "--context", "--extension-sdk-path",
}

# Effort flags get value translation (Claude Code's 'ultracode' level has no
# Copilot CLI equivalent).
EFFORT_FLAGS = {"--effort", "--reasoning-effort"}


def warn(msg):
    print(f"cpc: warning: {msg}", file=sys.stderr)


def translate_effort_value(value):
    """Translate a Claude Code effort level to a Copilot CLI effort level.

    Copilot CLI accepts low|medium|high|xhigh|max. Claude Code's 'ultracode'
    (xhigh reasoning plus automatic workflow orchestration) has no equivalent,
    so it's mapped to the closest level, 'max', with a warning.
    """
    if value == "ultracode":
        warn("Copilot CLI has no 'ultracode' effort level (Claude Code-only: "
             "combines xhigh reasoning with automatic workflow orchestration). "
             "Mapping to 'max'")
        return "max"
    return value


def is_flag(s):
    return s.startswith("-")


def consume_values(args, start):
    """Consume non-flag values starting after args[start]. Return (values, next_index)."""
    values = []
    i = start + 1
    while i < len(args) and not is_flag(args[i]):
        values.append(args[i])
        i += 1
    return values, i


# ---------------------------------------------------------------------------
# Subcommand handlers
# ---------------------------------------------------------------------------

def handle_auth(rest_args):
    """Translate 'auth login|logout|status' to copilot equivalents."""
    if not rest_args:
        warn("'auth' requires a subcommand: login, logout, or status")
        return [COPILOT_BIN, "login"]

    sub = rest_args[0]
    if sub == "login":
        extra_flags = rest_args[1:]
        if extra_flags:
            warn(f"Auth flags {extra_flags} are not supported by Copilot CLI (ignored)")
        return [COPILOT_BIN, "login"]
    elif sub == "logout":
        warn("'copilot logout' subcommand has been removed. Use /logout in an interactive session instead")
        return None
    elif sub == "status":
        warn("Copilot CLI doesn't have 'auth status'; showing version info instead")
        return [COPILOT_BIN, "version"]
    else:
        warn(f"Unknown auth subcommand '{sub}'")
        return [COPILOT_BIN, "login"]


SUBCOMMANDS = {
    "update", "init", "plugin", "auth", "agents", "mcp",
    "remote-control", "auto-mode", "autofix-pr", "web-setup",
    "team-onboarding", "loop", "proactive",
    # Background agent session management (new in Claude Code)
    "attach", "logs", "respawn", "rm", "stop", "daemon",
    "ultrareview", "project", "setup-token", "install",
}


def handle_subcommand(subcmd, rest_args):
    """Route Claude Code subcommands to Copilot equivalents.

    Returns the full argv list for exec, or None if not a subcommand.
    """
    if subcmd == "update":
        return [COPILOT_BIN, "update"] + rest_args
    if subcmd == "init":
        return [COPILOT_BIN, "init"] + rest_args
    if subcmd == "plugin":
        return [COPILOT_BIN, "plugin"] + rest_args
    if subcmd == "auth":
        return handle_auth(rest_args)
    if subcmd == "agents":
        warn("Use /agent inside an interactive Copilot CLI session to browse agents")
        return [COPILOT_BIN]
    if subcmd == "mcp":
        return [COPILOT_BIN, "mcp"] + rest_args
    if subcmd == "remote-control":
        warn("Remote control is not available as a subcommand. Use /remote [on|off] inside a Copilot CLI session, or --remote flag")
        return None
    if subcmd == "auto-mode":
        sub = rest_args[0] if rest_args else None
        if sub == "config":
            warn("No direct Copilot CLI equivalent for 'auto-mode config'. "
                 "Use --autopilot flag or Shift+Tab in interactive mode")
            return None
        if sub == "defaults":
            warn("No direct Copilot CLI equivalent for 'auto-mode defaults'. "
                 "Use --autopilot flag or Shift+Tab in interactive mode")
            return None
        warn("Use --autopilot flag or Shift+Tab in interactive mode")
        return [COPILOT_BIN]
    if subcmd == "autofix-pr":
        warn("Not available in Copilot CLI. See https://docs.anthropic.com/en/docs/claude-code/claude-code-on-the-web")
        return None
    if subcmd == "web-setup":
        warn("Not available in Copilot CLI. See https://docs.anthropic.com/en/docs/claude-code/web-quickstart#connect-from-your-terminal")
        return None
    if subcmd == "team-onboarding":
        warn("Not available in Copilot CLI. /team-onboarding relies on Claude Code session history")
        return None
    if subcmd in ("loop", "proactive"):
        warn("Not available in Copilot CLI. /loop (/proactive) runs a prompt repeatedly while the session stays open")
        return None
    # --- Background agent session management ---
    if subcmd == "attach":
        warn("Not available in Copilot CLI. Background agent session management is Claude Code-only. "
             "Closest: resume a session with 'copilot --resume'")
        return None
    if subcmd == "logs":
        warn("Not available in Copilot CLI. Background agent session management is Claude Code-only")
        return None
    if subcmd == "respawn":
        warn("Not available in Copilot CLI. Background agent session management is Claude Code-only. "
             "'claude respawn' restarts a running or stopped background session "
             "(--all restarts every running session). Closest: resume a session with 'copilot --resume'")
        return None
    if subcmd == "rm":
        warn("Not available in Copilot CLI. Background agent session management is Claude Code-only. "
             "Use /session delete <ID> inside a Copilot CLI session to remove sessions")
        return None
    if subcmd == "stop":
        warn("Not available in Copilot CLI. Background agent session management is Claude Code-only")
        return None
    if subcmd == "daemon":
        sub = rest_args[0] if rest_args else None
        if sub == "status":
            warn("Not available in Copilot CLI. 'claude daemon status' reports state of Claude Code's "
                 "background-session supervisor, which has no Copilot CLI counterpart")
            return None
        warn("Not available in Copilot CLI. 'claude daemon' manages Claude Code's background-session "
             "supervisor, which has no Copilot CLI counterpart")
        return None
    if subcmd == "ultrareview":
        warn("Not available in Copilot CLI. Use /review inside a Copilot CLI session for local reviews")
        return None
    if subcmd == "project":
        sub = rest_args[0] if rest_args else None
        if sub == "purge":
            warn("Not available in Copilot CLI. Use /session cleanup or /session prune inside a session")
            return None
        warn(f"Unknown 'project' subcommand '{sub}'")
        return None
    if subcmd == "setup-token":
        warn("Not available in Copilot CLI. Use 'gh auth token' for CI/script authentication with GitHub")
        return None
    if subcmd == "install":
        warn("Not available in Copilot CLI. Use 'copilot update' to update, or reinstall via your package manager")
        return None
    return None


